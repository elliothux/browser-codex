{
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "bun run format:check && bun run typecheck && bun run lint",
    "check:staged": "lint-staged",
    "format": "prettier --write --log-level warn . && cargo fmt --all",
    "format:check": "prettier --check --log-level warn . && cargo fmt --all --check",
    "lint": "bun run lint:ts && bun run lint:rust",
    "lint:fix": "oxlint --fix . --ignore-pattern 'external/**' --ignore-pattern 'pkg/**' --ignore-pattern 'apps/web/public/wasm/**' --ignore-pattern 'apps/web/src/routeTree.gen.ts'",
    "lint:rust": "cargo clippy -p codex-browser-core --all-targets -- -D warnings",
    "lint:ts": "oxlint . --ignore-pattern 'external/**' --ignore-pattern 'pkg/**' --ignore-pattern 'apps/web/public/wasm/**' --ignore-pattern 'apps/web/src/routeTree.gen.ts'",
    "prepare": "simple-git-hooks",
    "typecheck": "bun run typecheck:ts && bun run typecheck:rust",
    "typecheck:rust": "cargo check -p codex-browser-core --target wasm32-unknown-unknown",
    "typecheck:ts": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck && tsc --noEmit --project tsconfig.tools.json",
    "ui:add": "bun run ./scripts/ui-add.ts",
    "web:build": "bun run web:wasm && bun run --cwd apps/web build",
    "web:dev": "bun run web:wasm && bun run --cwd apps/web dev",
    "web:wasm": "bash -c 'cd crates/codex-browser-core && wasm-pack build --target web --out-dir ../../apps/web/public/wasm/codex-browser-core'"
  },
  "simple-git-hooks": {
    "pre-commit": "test -f \"$(git rev-parse --git-path MERGE_HEAD)\" && exit 0 || bun run check:staged"
  },
  "lint-staged": {
    "*": "prettier --write --log-level warn --ignore-unknown",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*.rs": "cargo fmt --"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@browser-codex/ui": "workspace:*",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.50.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3",
    "vite": "^8.0.0"
  }
}
